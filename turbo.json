{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "stream",
  "globalDependencies": ["tsconfig.base.json", "biome.json"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "tsconfig.json", "package.json"],
      "outputs": ["dist/**", "!dist/**/*.d.ts.map"]
    },
    "@nexus-hems/shared-types#build": {
      "inputs": ["src/**", "tsconfig.json", "package.json"],
      "outputs": []
    },
    "@nexus-hems/web#build": {
      "dependsOn": ["@nexus-hems/shared-types#build"],
      "env": [
        "VITE_E2E_TESTING",
        "VITE_BACKEND_WS",
        "VITE_ADAPTER_MODE",
        "VITE_ALLOW_LIVE_HARDWARE"
      ],
      "inputs": [
        "src/**",
        "public/**",
        "index.html",
        "vite.config.ts",
        "tailwind.config.ts",
        "tsconfig.json",
        "package.json"
      ],
      "outputs": ["dist/**", ".lighthouseci/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "inputs": ["src/**", "tsconfig.json", "../../biome.json", "../../eslint.config.js"],
      "outputs": []
    },
    "lint:fix": {
      "cache": false
    },
    "format": {
      "cache": false
    },
    "type-check": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "tsconfig.json"],
      "outputs": []
    },
    "test:run": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "tsconfig.json", "vitest.config.ts"],
      "outputs": []
    },
    "test": {
      "cache": false,
      "persistent": true
    },
    "test:e2e": {
      "dependsOn": ["build"],
      "inputs": ["tests/**", "playwright.config.ts"],
      "outputs": ["playwright-report/**", "test-results/**"]
    },
    "test:fuzz": {
      "inputs": ["src/tests/security-fuzz.test.ts", "vitest.config.ts"],
      "outputs": []
    },
    "test:coverage": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "tsconfig.json", "vitest.config.ts"],
      "outputs": ["coverage/**"]
    },
    "storybook:build": {
      "inputs": ["src/**", ".storybook/**"],
      "outputs": ["storybook-static/**"]
    },
    "size": {
      "dependsOn": ["build"],
      "inputs": ["dist/**", "package.json"],
      "outputs": []
    }
  }
}
