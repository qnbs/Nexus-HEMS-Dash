{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "image": {
      "type": "object",
      "properties": {
        "trustedRegistries": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9.-]+(?:\/[a-z0-9._-]+)+\/$"
          }
        },
        "frontend": {
          "type": "object",
          "properties": {
            "repository": {
              "type": "string",
              "pattern": "^[a-z0-9.-]+(?:\/[a-z0-9._-]+)+$"
            },
            "tag": {
              "type": "string"
            },
            "digest": {
              "type": "string"
            },
            "pullPolicy": {
              "type": "string"
            }
          },
          "required": ["repository", "pullPolicy"]
        },
        "server": {
          "type": "object",
          "properties": {
            "repository": {
              "type": "string",
              "pattern": "^[a-z0-9.-]+(?:\/[a-z0-9._-]+)+$"
            },
            "tag": {
              "type": "string"
            },
            "digest": {
              "type": "string"
            },
            "pullPolicy": {
              "type": "string"
            }
          },
          "required": ["repository", "pullPolicy"]
        }
      },
      "required": ["trustedRegistries", "frontend", "server"]
    }
  }
}
