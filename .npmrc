# ── Nexus-HEMS-Dash — pnpm / npm Configuration ──────────────────
# Enforces consistent, reproducible installs across local, CI, and Codespaces.

# Reject installs on unsupported Node versions (requires package.json engines)
engine-strict=true

# Fail on unresolved peer dependency conflicts
strict-peer-dependencies=true

# Auto-install missing peer dependencies
auto-install-peers=true

# Deduplicate peer dependents to reduce node_modules bloat
dedupe-peer-dependents=true

# Use the default pnpm content-addressable store
# (helps with Codespaces prebuilds — installs are near-instant on cache hit)
prefer-frozen-lockfile=true

# Prevent accidental npm/yarn usage (corepack should handle this, belt & suspenders)
package-manager-strict=true

# ── Monorepo Performance & Correctness ───────────────────────────
# Resolve workspace packages before registry (prevents version mismatches)
prefer-workspace-packages=true
# Hoist all packages so cross-workspace binaries and types are accessible
hoist-pattern=*
public-hoist-pattern=*
