# ──────────────────────────────────────────────────────────────────
# Nexus-HEMS Dash – Environment Configuration
# Copy to .env and fill in your values.
# All variables are optional — the dashboard works without them.
#
# GitHub Codespaces: Use Codespaces Secrets instead of .env files.
# See: https://github.com/settings/codespaces
#
# Full reference (every variable, scope, default, required):
#   docs/Environment-Variables.md
# ──────────────────────────────────────────────────────────────────

# ── AI Optimizer ─────────────────────────────────────────
# AI API keys are now managed via the BYOK Settings page (/settings/ai)
# with AES-GCM 256-bit encryption in IndexedDB.
# No AI keys needed in environment variables.

# ── JWT / Server Auth ──────────────────────────────────────────
# HMAC-SHA256 secret for signing JWTs. Min 32 characters (64+ recommended).
# SECURITY: Use a cryptographically random value in production!
# Generate with: openssl rand -base64 64
# In Docker: mount as /run/secrets/jwt_secret (preferred — never in env vars).
# In K8s: use a Secret mounted as a file, not an env var.
# If unset in dev mode, a random secret is auto-generated per run (NOT for production).
# NEVER use: "password", "secret", "changeme", dictionary words, or short values.
JWT_SECRET=

# API Keys for /api/auth/token endpoint (comma-separated).
# Clients must provide a valid key to obtain a JWT.
# In dev mode, this is optional (anonymous access allowed).
# In production, set at least one strong API key.
# Generate with: openssl rand -hex 32
API_KEYS=

# Required in production: bind each API key to a maximum scope (read|readwrite|admin).
# Example: API_KEY_SCOPES=monitor:read,operator:readwrite,admin:admin
API_KEY_SCOPES=

# ── CORS & WebSocket Origins ───────────────────────────────────────
# Comma-separated list of allowed origins for CORS (in addition to defaults).
# Example: https://dashboard.example.com,https://admin.example.com
CORS_ORIGINS=

# Comma-separated list of allowed WebSocket origins for CSP connect-src.
# Required in production if using WebSockets.
# Example: wss://ws.example.com,wss://api.example.com
WS_ORIGINS=

# ── Backend OpenEMS Edge (JSON-RPC WebSocket, live mode only) ─────
# OPENEMS_HOST=192.168.1.60
# OPENEMS_PORT=8085
# OPENEMS_TLS=false
# OPENEMS_AUTH_TOKEN=user
# OPENEMS_DEVICE_ID=openems-edge
# OPENEMS_POLL_MS=5000
# Controller IDs used for OpenEMS command dispatch (defaults are shown).
# OPENEMS_EVCS_CTRL_ID=ctrlEvcs0
# OPENEMS_ESS_CTRL_ID=ctrlEssFixActivePower0
# OPENEMS_PEAK_SHAVING_CTRL_ID=ctrlPeakShaving0
# OPENEMS_HP_SGREADY_CTRL_ID=ctrlIoHeatPumpSgReady0

# ── Backend OCPP 2.1 CSMS gateway (live mode only) ──────────────
# OCPP_CSMS_PORT=9000
# OCPP_CSMS_HOST=0.0.0.0
# OCPP_CSMS_PATH=/ocpp

# ── Backend Matter/Thread bridge (live mode only) ────────────────
# WebSocket host of the python-matter-server / HA Matter Server.
# MATTER_BRIDGE_HOST=matter.local

# ── Backend Zigbee2MQTT bridge (live mode only) ──────────────────
# MQTT broker URL for the Zigbee2MQTT bridge.
# Z2M_BROKER_URL=mqtt://localhost:1883

# Comma-separated list of trusted IPs that bypass rate limiting.
# Use for internal load balancers or trusted proxies.
# Example: 10.0.0.1,192.168.1.1
RATE_LIMIT_TRUSTED_IPS=

# ── Adapter Mode (Safety-Critical) ─────────────────────────────
# Default is mock — no real hardware connections without explicit opt-in.
# Read docs/Safety-Certification-Notice.md before enabling live mode.
ADAPTER_MODE=mock
# Required together with ADAPTER_MODE=live to start backend protocol adapters:
# ALLOW_LIVE_HARDWARE=true

# ── Read-Only Mode (Safety-Critical) ───────────────────────────
# When true, ALL hardware control commands are blocked at the API level,
# regardless of scope or adapter configuration. Use for commissioning,
# incident investigation, and certification-grade deployments.
READ_ONLY_MODE=false

# Frontend build-time mirror (Vite). Unset = mock (no auto hardware connect).
# VITE_ADAPTER_MODE=mock
# VITE_ALLOW_LIVE_HARDWARE=true

# Opt-in: browser consumes the backend EventBus→WebSocket broadcast (ADR-025).
# Unset/false = client-side adapters only (gh-pages static demo default).
# Set to true ONLY for full-stack deployments where the Express API is reachable.
# VITE_BACKEND_WS=true

# ── Victron Cerbo GX (Node-RED WebSocket) ──────────────────────
VITE_VICTRON_WS_HOST=192.168.1.100
VITE_VICTRON_WS_PORT=1880
# Set to "true" to enable TLS (wss://)
VITE_VICTRON_WS_TLS=false

# ── Modbus TCP / SunSpec REST Gateway ──────────────────────────
VITE_MODBUS_HOST=192.168.1.100
VITE_MODBUS_PORT=502
VITE_MODBUS_POLL_INTERVAL_MS=3000

# ── KNX/IP Gateway ────────────────────────────────────────────
VITE_KNX_HOST=192.168.1.101
VITE_KNX_PORT=3671

# ── OCPP 2.1 CSMS (EV Charging) ──────────────────────────────
VITE_OCPP_HOST=192.168.1.200
VITE_OCPP_PORT=9000
VITE_OCPP_TLS=true
# Charge-point identity for OCPP BootNotification
VITE_OCPP_CHARGE_POINT_ID=nexus-cp-01

# ── Dynamic Tariffs ──────────────────────────────────────────
VITE_TIBBER_API_TOKEN=
VITE_AWATTAR_COUNTRY=DE

# ── MQTT Broker (Home Assistant) ─────────────────────────────
VITE_MQTT_BROKER_URL=ws://your-mqtt-broker:9001

# ── Custom Script Execution (ExecAdapter) ──────────────────────
# Server-side whitelist of scripts the ExecAdapter may run.
# Accepts a JSON string or a path (absolute or relative) to a JSON file.
# Example: {"poll-shelly":{"path":"/opt/nexus/scripts/poll-shelly.sh","args":["deviceId"]}}
# EXEC_SCRIPTS_CONFIG=

# ══════════════════════════════════════════════════════════════════
# Additional backend / live-mode options (all optional; see
# docs/Environment-Variables.md for the complete reference)
# ══════════════════════════════════════════════════════════════════

# ── Core server ───────────────────────────────────────────────
# PORT=3000
# LOG_LEVEL=info                 # error | warn | info | debug
# NODE_ENV=production
# TRUST_PROXY=true               # set when behind nginx / K8s ingress
# WEB_DIST_PATH=../web/dist

# ── JWT rotation (zero-downtime, HIGH-07) ─────────────────────
# JWT_SECRET_FILE=/run/secrets/jwt_secret
# JWT_SECRET_NEW=                # second key: both verify, new key signs
# JWT_KID_PRIMARY=
# JWT_KID_NEW=

# ── WebSocket limits ──────────────────────────────────────────
# WS_RATE_LIMIT=30               # hardware commands / client / minute
# WS_MAX_CONNECTIONS_PER_IP=50

# ── InfluxDB (live time-series) ───────────────────────────────
# INFLUXDB_URL=http://influxdb:8086
# INFLUXDB_TOKEN=change-me       # default token is NOT production-safe
# INFLUXDB_ORG=nexus-hems
# INFLUXDB_BUCKET=nexus-hems

# ── Redis (JTI revocation + EEBUS trust store) ────────────────
# REDIS_URL=redis://localhost:6379

# ── Backend Victron MQTT (live mode) ──────────────────────────
# MQTT_BROKER_URL=mqtts://venus.local:8883
# MQTT_USERNAME=
# MQTT_PASSWORD=
# MQTT_CA_CERT=   # MQTT_CLIENT_CERT / MQTT_CLIENT_KEY for mTLS

# ── Backend KNX / evcc (live mode) ────────────────────────────
# KNX_BRIDGE_WS_URL=ws://knxd-host:8080
# EVCC_BASE_URL=http://evcc.local:7070
# EVCC_AUTH_TOKEN=
# EVCC_DEVICE_ID=

# ── Backend EEBUS (mTLS SHIP, live mode) ──────────────────────
# EEBUS_DISABLE=false
# EEBUS_CERT_FILE=data/eebus-server.cert.pem
# EEBUS_KEY_FILE=data/eebus-server.key.pem
# EEBUS_CA_FILE=
# EEBUS_TRUST_BACKEND=file       # file | redis (redis uses REDIS_URL)
# EEBUS_TRUST_FILE=data/eebus-trust.json

# ── Backend HeatPump (live mode) ──────────────────────────────
# HEATPUMP_HOST=192.168.1.70
# HEATPUMP_PORT=502
# HEATPUMP_UNIT_ID=1
# HEATPUMP_MANUFACTURER=generic  # stiebel | viessmann | wolf | nibe | alpha | daikin
# HEATPUMP_POLL_MS=5000

# ── Backend Home Assistant (ha-ws-api / MQTT transports) ──────
# HA_HOST=homeassistant.local
# HA_PORT=8123
# HA_TLS=false
# HA_TOKEN=                      # long-lived access token
# HA_ENTITY_MAP_PATH=            # + HA_WALLBOX_*, HA_HEAT_PUMP_MODE_ENTITY overrides
# HA_MQTT_BROKER_URL=mqtt://localhost:1883

# ── OpenADR 3.1 VEN (demand response) ─────────────────────────
# OPENADR_VTN_URL=
# OPENADR_CLIENT_ID=
# OPENADR_CLIENT_SECRET=

# ── Tariff proxy + frontend extras ────────────────────────────
# AWATTAR_BASE_URL=https://api.awattar.de/v1
# VITE_API_URL=                  # override API base URL
# VITE_READ_ONLY_MODE=false
# VITE_ADAPTER_WORKER=false      # poll REST adapters off-thread
# VITE_SENTRY_DSN=               # optional SPA error reporting

# ── Experimental: in-browser local-LLM engines (deferred, ADR-029) ──
# Off by default — the WebLLM/Transformers.js/ONNX engines cannot load under the
# production CSP and their peer packages are not shipped. Opt-in also requires
# re-adding the peer package to packages/ai-core. See docs/Environment-Variables.md.
# VITE_ENABLE_LOCAL_LLM=false    # web build flag
# ENABLE_LOCAL_LLM=false         # Node/API equivalent
