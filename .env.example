# ──────────────────────────────────────────────────────────────────
# Nexus-HEMS Dash – Environment Configuration
# Copy to .env and fill in your values.
# All variables are optional — the dashboard works without them.
# ──────────────────────────────────────────────────────────────────

# ── AI Optimizer (Google Gemini) ─────────────────────────────
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# ── App URL (AI Studio / Cloud Run) ─────────────────────────
APP_URL="MY_APP_URL"

# ── Victron Cerbo GX (Node-RED WebSocket) ──────────────────────
VITE_VICTRON_WS_HOST=192.168.1.100
VITE_VICTRON_WS_PORT=1880
# Set to "true" to enable TLS (wss://)
VITE_VICTRON_WS_TLS=false

# ── Modbus TCP / SunSpec REST Gateway ──────────────────────────
VITE_MODBUS_HOST=192.168.1.100
VITE_MODBUS_PORT=502
VITE_MODBUS_POLL_INTERVAL_MS=3000

# ── KNX/IP Gateway ────────────────────────────────────────────
VITE_KNX_HOST=192.168.1.101
VITE_KNX_PORT=3671

# ── OCPP 2.1 CSMS (EV Charging) ──────────────────────────────
VITE_OCPP_HOST=192.168.1.200
VITE_OCPP_PORT=9000
VITE_OCPP_TLS=true
# Charge-point identity for OCPP BootNotification
VITE_OCPP_CHARGE_POINT_ID=nexus-cp-01

# ── Dynamic Tariffs ──────────────────────────────────────────
VITE_TIBBER_API_TOKEN=
VITE_AWATTAR_COUNTRY=DE

# ── MQTT Broker (Home Assistant) ─────────────────────────────
VITE_MQTT_BROKER_URL=ws://your-mqtt-broker:9001
