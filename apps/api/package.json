{
  "name": "@nexus-hems/api",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "description": "Nexus-HEMS Express 5 backend — JWT auth, WebSocket, protocol adapters",
  "scripts": {
    "dev": "tsx --watch index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "lint": "biome check src/ index.ts --config-path ../../biome.json"
  },
  "dependencies": {
    "@nexus-hems/shared-types": "workspace:*",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "jose": "^6.2.1",
    "mqtt": "^5.12.2",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.0.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
