{
  "name": "@nexus-hems/web",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "description": "Nexus-HEMS React 19 SPA — Vite 8, Tailwind v4, Zustand 5, TanStack Query v5",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "lint": "biome check src/ && eslint src/ --max-warnings 0",
    "lint:fix": "biome check --write src/ && eslint src/ --fix --max-warnings 0",
    "format": "biome format --write src/",
    "test": "vitest",
    "test:run": "vitest run",
    "test:fuzz": "vitest run src/tests/security-fuzz.test.ts",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:a11y": "playwright test tests/e2e/accessibility.spec.ts",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build --output-dir storybook-static",
    "lighthouse": "lhci autorun",
    "size": "size-limit",
    "cap:sync": "npx cap sync",
    "cap:build": "pnpm build && npx cap sync"
  },
  "dependencies": {
    "@nexus-hems/shared-types": "workspace:*",
    "@capacitor/app": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/haptics": "^7.0.0",
    "@capacitor/local-notifications": "^7.0.0",
    "@capacitor/push-notifications": "^7.0.0",
    "@capacitor/splash-screen": "^7.0.0",
    "@capacitor/status-bar": "^7.0.0",
    "@google/genai": "^1.29.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@radix-ui/react-visually-hidden": "^1.2.4",
    "@sentry/react": "^9.47.1",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@tanstack/react-virtual": "^3.13.21",
    "clsx": "^2.1.1",
    "comlink": "^4.4.2",
    "d3-sankey": "^0.12.3",
    "d3-selection": "^3.0.0",
    "date-fns": "^4.1.0",
    "dexie": "^4.3.0",
    "i18next": "^25.8.14",
    "i18next-browser-languagedetector": "^8.2.1",
    "jose": "^6.2.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "mqtt": "^5.12.2",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^16.5.6",
    "react-is": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@babel/core": "^7.29.0",
    "@babel/eslint-parser": "^7.28.6",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@capacitor/cli": "^7.0.0",
    "@chromatic-com/storybook": "^5.1.2",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.58.2",
    "@rolldown/plugin-babel": "^0.2.3",
    "@size-limit/file": "^12.0.1",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/react": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/d3-sankey": "^0.12.5",
    "@types/d3-selection": "^3.0.11",
    "@types/node": "^24.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/trusted-types": "^2.0.7",
    "@typescript/native-preview": "7.0.0-dev.20260424.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "anti-trojan-source": "^1.8.1",
    "autoprefixer": "^10.4.21",
    "babel-plugin-react-compiler": "^1.0.0",
    "chromatic": "^16.2.0",
    "eslint": "^9.39.3",
    "eslint-plugin-react-compiler": "^19.1.0-rc.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fake-indexeddb": "^6.2.5",
    "fast-check": "^4.6.0",
    "jsdom": "^29.0.2",
    "rollup-plugin-visualizer": "^7.0.1",
    "size-limit": "^12.0.1",
    "source-map-explorer": "^2.5.3",
    "storybook": "^10.3.5",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^8.0.8",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.4",
    "workbox-window": "^7.4.0"
  },
  "size-limit": [
    {
      "name": "Framework (React + Router + Zustand)",
      "path": "dist/assets/framework-*.js",
      "limit": "85 kB",
      "gzip": true
    },
    {
      "name": "App Entry",
      "path": "dist/assets/index-*.js",
      "limit": "70 kB",
      "gzip": true
    },
    {
      "name": "Adapters (protocol layer)",
      "path": "dist/assets/adapters-*.js",
      "limit": "35 kB",
      "gzip": true
    },
    {
      "name": "Vendor D3",
      "path": "dist/assets/vendor-d3-*.js",
      "limit": "30 kB",
      "gzip": true
    },
    {
      "name": "Vendor Recharts",
      "path": "dist/assets/vendor-recharts-*.js",
      "limit": "110 kB",
      "gzip": true
    },
    {
      "name": "Vendor Motion",
      "path": "dist/assets/vendor-motion-*.js",
      "limit": "45 kB",
      "gzip": true
    },
    {
      "name": "Vendor Icons",
      "path": "dist/assets/vendor-icons-*.js",
      "limit": "20 kB",
      "gzip": true
    },
    {
      "name": "Total JS",
      "path": "dist/assets/*.js",
      "limit": "1100 kB",
      "gzip": true
    },
    {
      "name": "Total CSS",
      "path": "dist/assets/*.css",
      "limit": "25 kB",
      "gzip": true
    }
  ]
}
