{
  "ci": {
    "collect": {
      "startServerCommand": "pnpm --filter @nexus-hems/web exec vite preview --host 0.0.0.0 --port 9876 --strictPort",
      "startServerReadyPattern": "Local:",
      "startServerReadyTimeout": 15000,
      "url": [
        "http://localhost:9876/Nexus-HEMS-Dash/",
        "http://localhost:9876/Nexus-HEMS-Dash/energy-flow",
        "http://localhost:9876/Nexus-HEMS-Dash/tariffs",
        "http://localhost:9876/Nexus-HEMS-Dash/analytics"
      ],
      "numberOfRuns": 3,
      "settings": {
        "preset": "desktop",
        "chromeFlags": "--no-sandbox --headless --disable-gpu --disable-dev-shm-usage",
        "onlyCategories": ["performance", "accessibility", "best-practices", "seo"],
        "budgets": [
          {
            "timings": [
              { "metric": "first-contentful-paint", "budget": 3000 },
              { "metric": "largest-contentful-paint", "budget": 4000 },
              { "metric": "interactive", "budget": 5500 },
              { "metric": "total-blocking-time", "budget": 400 },
              { "metric": "cumulative-layout-shift", "budget": 0.1 },
              { "metric": "speed-index", "budget": 4500 }
            ],
            "resourceSizes": [
              { "resourceType": "script", "budget": 700 },
              { "resourceType": "stylesheet", "budget": 100 },
              { "resourceType": "image", "budget": 500 },
              { "resourceType": "font", "budget": 150 },
              { "resourceType": "total", "budget": 1500 }
            ],
            "resourceCounts": [
              { "resourceType": "script", "budget": 25 },
              { "resourceType": "third-party", "budget": 10 }
            ]
          }
        ]
      }
    },
    "assert": {
      "preset": "lighthouse:recommended",
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.85, "aggregationMethod": "median" }],
        "categories:accessibility": ["error", { "minScore": 0.9 }],
        "categories:best-practices": ["error", { "minScore": 0.9 }],
        "categories:seo": ["error", { "minScore": 0.92 }],
        "first-contentful-paint": ["warn", { "maxNumericValue": 3000 }],
        "largest-contentful-paint": ["warn", { "maxNumericValue": 4000 }],
        "cumulative-layout-shift": ["error", { "maxNumericValue": 0.1 }],
        "total-blocking-time": ["error", { "maxNumericValue": 400 }],
        "interactive": ["warn", { "maxNumericValue": 5500 }],
        "speed-index": ["warn", { "maxNumericValue": 4500 }],
        "resource-summary:script:size": ["warn", { "maxNumericValue": 512000 }],
        "resource-summary:stylesheet:size": ["error", { "maxNumericValue": 102400 }],
        "resource-summary:total:size": ["warn", { "maxNumericValue": 1572864 }],
        "meta-description": "error",
        "document-title": "error",
        "html-has-lang": "error",
        "meta-viewport": "error",
        "font-display": "warn",
        "dom-size": ["warn", { "maxNumericValue": 2500 }],
        "uses-responsive-images": "warn",
        "render-blocking-resources": "off",
        "errors-in-console": "off",
        "unsized-images": "warn",
        "unused-javascript": "warn",
        "uses-long-cache-ttl": "warn",
        "uses-text-compression": "warn",
        "tap-targets": "off",
        "redirects": "off",
        "bootup-time": "off",
        "mainthread-work-breakdown": "off",
        "legacy-javascript": "off",
        "network-dependency-tree-insight": "off",
        "forced-reflow-insight": "off",
        "render-blocking-insight": "off",
        "inspector-issues": "off"
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
