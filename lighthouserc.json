{
  "ci": {
    "collect": {
      "staticDistDir": "./dist",
      "url": [
        "http://localhost/index.html",
        "http://localhost/energy-flow",
        "http://localhost/tariffs",
        "http://localhost/analytics"
      ],
      "numberOfRuns": 3,
      "settings": {
        "chromeFlags": "--no-sandbox --headless --disable-gpu --disable-dev-shm-usage",
        "onlyCategories": ["performance", "accessibility", "best-practices", "seo"],
        "budgets": [
          {
            "timings": [
              { "metric": "first-contentful-paint", "budget": 1800 },
              { "metric": "largest-contentful-paint", "budget": 2500 },
              { "metric": "interactive", "budget": 3800 },
              { "metric": "total-blocking-time", "budget": 250 },
              { "metric": "cumulative-layout-shift", "budget": 0.1 },
              { "metric": "speed-index", "budget": 3400 }
            ],
            "resourceSizes": [
              { "resourceType": "script", "budget": 350 },
              { "resourceType": "stylesheet", "budget": 100 },
              { "resourceType": "image", "budget": 500 },
              { "resourceType": "font", "budget": 150 },
              { "resourceType": "total", "budget": 1100 }
            ],
            "resourceCounts": [
              { "resourceType": "script", "budget": 25 },
              { "resourceType": "third-party", "budget": 10 }
            ]
          }
        ]
      }
    },
    "assert": {
      "preset": "lighthouse:recommended",
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.9, "aggregationMethod": "median" }],
        "categories:accessibility": ["error", { "minScore": 0.9 }],
        "categories:best-practices": ["error", { "minScore": 0.9 }],
        "categories:seo": ["error", { "minScore": 0.92 }],
        "first-contentful-paint": ["error", { "maxNumericValue": 1800 }],
        "largest-contentful-paint": ["error", { "maxNumericValue": 2500 }],
        "cumulative-layout-shift": ["error", { "maxNumericValue": 0.1 }],
        "total-blocking-time": ["error", { "maxNumericValue": 250 }],
        "interactive": ["error", { "maxNumericValue": 3800 }],
        "speed-index": ["error", { "maxNumericValue": 3400 }],
        "resource-summary:script:size": ["error", { "maxNumericValue": 358400 }],
        "resource-summary:stylesheet:size": ["error", { "maxNumericValue": 102400 }],
        "resource-summary:total:size": ["error", { "maxNumericValue": 1153434 }],
        "meta-description": "error",
        "document-title": "error",
        "html-has-lang": "error",
        "meta-viewport": "error",
        "font-display": "warn",
        "dom-size": ["warn", { "maxNumericValue": 1500 }],
        "uses-responsive-images": "warn",
        "render-blocking-resources": "warn",
        "unsized-images": "warn",
        "unused-javascript": "warn",
        "uses-long-cache-ttl": "warn",
        "uses-text-compression": "warn",
        "tap-targets": "warn"
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
