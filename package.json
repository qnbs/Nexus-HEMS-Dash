{
  "name": "nexus-hems-dash",
  "private": true,
  "version": "1.6.1",
  "description": "Real-time Home Energy Management System dashboard — 13 protocol adapters (Victron, Modbus, KNX, OCPP 2.1, EEBUS, evcc, OpenEMS + Home Assistant, Matter/Thread, Zigbee2MQTT, Shelly, OpenADR 3.1), plugin system with adapter registry, dynamic tariffs (Tibber/aWATTar/Octopus/Nordpool), SG Ready, AI optimizer, WCAG 2.2 AA",
  "keywords": [
    "hems",
    "energy-management",
    "smart-home",
    "victron",
    "knx",
    "eebus",
    "ocpp",
    "tibber",
    "awattar",
    "octopus-energy",
    "home-assistant",
    "matter-thread",
    "zigbee2mqtt",
    "shelly",
    "adapter-registry",
    "plugin-system",
    "capacitor",
    "sg-ready",
    "react",
    "typescript",
    "d3-sankey",
    "pwa",
    "zustand",
    "tailwindcss",
    "wcag",
    "accessibility",
    "react-compiler",
    "vite"
  ],
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.22.1",
    "pnpm": ">=10.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "better-sqlite3",
      "@serialport/bindings-cpp",
      "core-js",
      "protobufjs",
      "@rolldown/binding-darwin-arm64",
      "@rolldown/binding-darwin-x64",
      "@rolldown/binding-linux-arm64-gnu",
      "@rolldown/binding-linux-arm64-musl",
      "@rolldown/binding-linux-x64-gnu",
      "@rolldown/binding-linux-x64-musl",
      "@rolldown/binding-win32-arm64-msvc",
      "@rolldown/binding-win32-ia32-msvc",
      "@rolldown/binding-win32-x64-msvc"
    ],
    "peerDependencyRules": {
      "allowedVersions": {
        "vite-plugin-pwa>vite": "^8.0.0",
        "@storybook/react>react": "^19.0.0",
        "@storybook/react>react-dom": "^19.0.0"
      }
    },
    "overrides": {
      "serialize-javascript": ">=7.0.5",
      "@rollup/plugin-terser": ">=0.4.5",
      "@xmldom/xmldom": ">=0.9.0",
      "basic-ftp": ">=5.3.1",
      "cross-spawn": ">=7.0.6",
      "protobufjs": "^7.5.5",
      "undici": "^7.28.0",
      "brace-expansion@^1.0.0": "1.1.14",
      "brace-expansion@^2.0.0": "2.1.0",
      "brace-expansion@^5.0.0": "5.0.7",
      "ws@^7.0.0": ">=7.5.11",
      "dompurify": ">=3.4.11",
      "qs": ">=6.15.2",
      "uuid": ">=11.1.1",
      "form-data": ">=4.0.6",
      "tar": ">=7.5.16",
      "js-yaml": ">=4.2.0",
      "esbuild": ">=0.28.1",
      "flatted": "3.4.2",
      "handlebars": "4.7.9",
      "lodash": "4.18.1",
      "lodash-es": "4.18.1",
      "npm>brace-expansion": "2.1.0",
      "npm>picomatch": "4.0.4",
      "picomatch@^2.0.0": "2.3.2",
      "picomatch@^4.0.0": "4.0.4",
      "@lhci/cli>tmp": ">=0.2.6",
      "external-editor>tmp": ">=0.2.6",
      "yaml@^1.0.0": "1.10.3",
      "yaml@^2.0.0": "2.8.3"
    }
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "build:analyze": "turbo build && echo 'Bundle stats: apps/web/dist/bundle-stats.html'",
    "preview": "turbo --filter=@nexus-hems/web preview",
    "clean": "turbo clean || true && rm -rf apps/*/dist packages/*/dist",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "format": "turbo format",
    "format:check": "biome format apps/ packages/",
    "type-check": "turbo type-check",
    "typecheck": "turbo type-check",
    "verify:basis": "turbo type-check lint test:run",
    "test": "turbo test",
    "test:run": "turbo test:run",
    "test:fuzz": "turbo --filter=@nexus-hems/web test:fuzz",
    "test:coverage": "turbo --filter=@nexus-hems/web test:coverage",
    "check:coverage-baseline": "node scripts/check-coverage-baseline.mjs",
    "test:e2e": "turbo --filter=@nexus-hems/web test:e2e",
    "test:e2e:ui": "turbo --filter=@nexus-hems/web test:e2e:ui",
    "test:a11y": "turbo --filter=@nexus-hems/web test:a11y",
    "security:trojan": "anti-trojan-source --files='{apps/{api,web}/src,apps/web/tests,packages/*/src}/**/*.{ts,tsx,js,jsx}' --verbose",
    "security:secrets": "node scripts/run-gitleaks.mjs git --verbose",
    "security:secrets:staged": "node scripts/run-gitleaks.mjs git --pre-commit --staged --verbose",
    "prepare": "husky",
    "start": "turbo --filter=@nexus-hems/api start",
    "docker:build": "docker build -t nexus-hems-dash .",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "lighthouse": "turbo --filter=@nexus-hems/web lighthouse",
    "size": "turbo --filter=@nexus-hems/web size",
    "storybook": "turbo --filter=@nexus-hems/web storybook",
    "storybook:build": "turbo --filter=@nexus-hems/web storybook:build",
    "release": "semantic-release",
    "release:dry": "semantic-release --dry-run",
    "graphify": "python -c 'import graphify; print(\"graphify CLI ready\")' && python -c 'from graphify.detect import detect; from pathlib import Path; print(\"Ready to run: pnpm graphify <path>\")'"
  },
  "devDependencies": {
    "@babel/core": "^7.29.6",
    "@babel/eslint-parser": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@biomejs/biome": "2.5.1",
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^21.0.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "anti-trojan-source": "^1.11.0",
    "conventional-changelog-conventionalcommits": "^10.2.0",
    "eslint": "^9.39.3",
    "eslint-plugin-react-compiler": "^19.1.0-rc.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "semantic-release": "^25.0.3",
    "turbo": "^2.9.14"
  }
}
