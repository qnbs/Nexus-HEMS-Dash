{
  "name": "nexus-hems-dash",
  "private": true,
  "version": "1.0.0",
  "description": "Real-time Home Energy Management System dashboard — 10 protocol adapters (Victron, Modbus, KNX, OCPP 2.1, EEBUS + Home Assistant, Matter/Thread, Zigbee2MQTT, Shelly), plugin system with adapter registry, dynamic tariffs (Tibber/aWATTar/Octopus/Nordpool), SG Ready, AI optimizer, WCAG 2.2 AA",
  "keywords": [
    "hems",
    "energy-management",
    "smart-home",
    "victron",
    "knx",
    "eebus",
    "ocpp",
    "tibber",
    "awattar",
    "octopus-energy",
    "home-assistant",
    "matter-thread",
    "zigbee2mqtt",
    "shelly",
    "adapter-registry",
    "plugin-system",
    "capacitor",
    "sg-ready",
    "react",
    "typescript",
    "d3-sankey",
    "pwa",
    "zustand",
    "tailwindcss",
    "wcag",
    "accessibility",
    "react-compiler",
    "vite"
  ],
  "type": "module",
  "packageManager": "pnpm@10.31.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "better-sqlite3"
    ],
    "peerDependencyRules": {
      "allowedVersions": {
        "vite-plugin-pwa>vite": "^8.0.0"
      }
    },
    "overrides": {
      "serialize-javascript": ">=7.0.5",
      "@rollup/plugin-terser": ">=0.4.5",
      "@xmldom/xmldom": "0.8.12",
      "basic-ftp": "5.2.2",
      "brace-expansion@^1.0.0": "1.1.14",
      "brace-expansion@^2.0.0": "2.1.0",
      "brace-expansion@^5.0.0": "5.0.5",
      "flatted": "3.4.2",
      "handlebars": "4.7.9",
      "lodash": "4.18.1",
      "lodash-es": "4.18.1",
      "npm>brace-expansion": "2.1.0",
      "npm>picomatch": "4.0.4",
      "picomatch@^2.0.0": "2.3.2",
      "picomatch@^4.0.0": "4.0.4",
      "@lhci/cli>tmp": "0.2.5",
      "external-editor>tmp": "0.2.5",
      "yaml@^1.0.0": "1.10.3",
      "yaml@^2.0.0": "2.8.3"
    }
  },
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build",
    "build:analyze": "vite build && echo 'Bundle stats: dist/bundle-stats.html'",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "eslint src tests server.ts vite.config.ts vitest.config.ts playwright.config.ts tailwind.config.ts capacitor.config.ts --max-warnings 0",
    "lint:fix": "eslint src tests server.ts vite.config.ts vitest.config.ts playwright.config.ts tailwind.config.ts capacitor.config.ts --fix",
    "lint:biome": "biome check src/",
    "lint:all": "pnpm lint && pnpm lint:biome",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\"",
    "type-check": "tsc --noEmit",
    "verify:basis": "pnpm type-check && pnpm lint && pnpm test:run",
    "test": "vitest",
    "test:run": "vitest run",
    "test:fuzz": "vitest run src/tests/security-fuzz.test.ts",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:a11y": "playwright test tests/e2e/accessibility.spec.ts",
    "security:trojan": "anti-trojan-source --files='src/**/*.{ts,tsx}' --verbose",
    "security:lint": "eslint src/ --rule 'anti-trojan-source/no-bidi: error'",
    "security:secrets": "gitleaks git --verbose",
    "security:secrets:staged": "gitleaks git --pre-commit --staged --verbose",
    "security:trivy": "trivy fs . --scanners vuln,secret,misconfig --severity HIGH,CRITICAL --config trivy.yaml",
    "prepare": "husky",
    "start": "node server.ts",
    "docker:build": "docker build -t nexus-hems-dash .",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "cap:init": "npx cap init Nexus-HEMS com.nexus.hems.dashboard --web-dir dist",
    "cap:add:android": "npx cap add android",
    "cap:add:ios": "npx cap add ios",
    "cap:sync": "npx cap sync",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "cap:build": "pnpm build && npx cap sync",
    "tauri:mobile:android": "npx tauri android init && npx tauri android dev",
    "tauri:mobile:ios": "npx tauri ios init && npx tauri ios dev",
    "lighthouse": "lhci autorun",
    "lighthouse:mobile": "lhci autorun --config=lighthouserc.json",
    "lighthouse:desktop": "lhci autorun --config=lighthouserc.json --collect.settings.preset=desktop",
    "size": "size-limit",
    "size:check": "size-limit --json",
    "analyze": "source-map-explorer dist/assets/*.js --html dist/source-map-report.html",
    "analyze:json": "source-map-explorer dist/assets/*.js --json dist/source-map-report.json",
    "depcheck": "depcheck --ignores='@types/*,autoprefixer,babel-plugin-react-compiler,eslint-*,prettier-*,@commitlint/*,anti-trojan-source,fake-indexeddb,globals,@tailwindcss/*,typescript-eslint,better-sqlite3,@biomejs/biome,@size-limit/*,source-map-explorer,depcheck,size-limit,@lhci/*,@vitest/*,@typescript-eslint/*,husky,lint-staged,workbox-window,vite-plugin-pwa,rollup-plugin-visualizer'",
    "perf": "pnpm build && pnpm size && pnpm analyze",
    "bench": "pnpm build && pnpm size:check > .perf/size-limit.json 2>&1 && echo 'Benchmark complete'",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build --output-dir storybook-static",
    "chromatic": "chromatic --exit-zero-on-changes",
    "release": "semantic-release",
    "release:dry": "semantic-release --dry-run"
  },
  "size-limit": [
    {
      "name": "Framework (React + Router + Zustand)",
      "path": "dist/assets/framework-*.js",
      "limit": "85 kB",
      "gzip": true
    },
    {
      "name": "App Entry",
      "path": "dist/assets/index-*.js",
      "limit": "70 kB",
      "gzip": true
    },
    {
      "name": "Adapters (protocol layer)",
      "path": "dist/assets/adapters-*.js",
      "limit": "35 kB",
      "gzip": true
    },
    {
      "name": "Vendor D3",
      "path": "dist/assets/vendor-d3-*.js",
      "limit": "30 kB",
      "gzip": true
    },
    {
      "name": "Vendor Recharts",
      "path": "dist/assets/vendor-recharts-*.js",
      "limit": "110 kB",
      "gzip": true
    },
    {
      "name": "Vendor Motion",
      "path": "dist/assets/vendor-motion-*.js",
      "limit": "45 kB",
      "gzip": true
    },
    {
      "name": "Vendor Icons",
      "path": "dist/assets/vendor-icons-*.js",
      "limit": "20 kB",
      "gzip": true
    },
    {
      "name": "Total JS",
      "path": "dist/assets/*.js",
      "limit": "1100 kB",
      "gzip": true
    },
    {
      "name": "Total CSS",
      "path": "dist/assets/*.css",
      "limit": "25 kB",
      "gzip": true
    }
  ],
  "dependencies": {
    "@capacitor/app": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/haptics": "^7.0.0",
    "@capacitor/local-notifications": "^7.0.0",
    "@capacitor/push-notifications": "^7.0.0",
    "@capacitor/splash-screen": "^7.0.0",
    "@capacitor/status-bar": "^7.0.0",
    "@google/genai": "^1.29.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@radix-ui/react-visually-hidden": "^1.2.4",
    "@sentry/react": "^9.47.1",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@tanstack/react-virtual": "^3.13.21",
    "clsx": "^2.1.1",
    "comlink": "^4.4.2",
    "cors": "^2.8.6",
    "d3-sankey": "^0.12.3",
    "d3-selection": "^3.0.0",
    "date-fns": "^4.1.0",
    "dexie": "^4.3.0",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "i18next": "^25.8.14",
    "i18next-browser-languagedetector": "^8.2.1",
    "jose": "^6.2.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "mqtt": "^5.12.2",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^16.5.6",
    "react-is": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.5.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@babel/core": "^7.29.0",
    "@biomejs/biome": "2.4.7",
    "@capacitor/cli": "^7.0.0",
    "@chromatic-com/storybook": "^5.1.2",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.39.4",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.58.2",
    "@rolldown/plugin-babel": "^0.2.3",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@size-limit/file": "^12.0.1",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/react": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/cors": "^2.8.19",
    "@types/d3-sankey": "^0.12.5",
    "@types/d3-selection": "^3.0.11",
    "@types/express": "^5.0.6",
    "@types/node": "^24.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/trusted-types": "^2.0.7",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "anti-trojan-source": "^1.8.1",
    "autoprefixer": "^10.4.21",
    "babel-plugin-react-compiler": "^1.0.0",
    "better-sqlite3": "^12.4.1",
    "chromatic": "^16.2.0",
    "conventional-changelog-conventionalcommits": "^8.0.0",
    "depcheck": "^1.4.7",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-anti-trojan-source": "^1.1.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-compiler": "^19.1.0-rc.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fake-indexeddb": "^6.2.5",
    "fast-check": "^4.6.0",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "rollup-plugin-visualizer": "^7.0.1",
    "semantic-release": "^24.2.3",
    "size-limit": "^12.0.1",
    "source-map-explorer": "^2.5.3",
    "storybook": "^10.3.5",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.8",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.4",
    "workbox-window": "^7.4.0"
  }
}
