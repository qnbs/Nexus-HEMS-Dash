# Pre-commit framework hooks (gitleaks, trailing-whitespace, etc.)
if command -v pre-commit >/dev/null 2>&1; then
  pre-commit run --config .pre-commit-config.yaml || exit 1
else
  # Fallback: run gitleaks directly if pre-commit not installed
  if command -v gitleaks >/dev/null 2>&1; then
    gitleaks git --pre-commit --staged --verbose
  else
    echo "⚠ Neither pre-commit nor gitleaks installed — skipping secret scan"
  fi
fi

# Format check: catch formatting issues before they reach CI
pnpm format:check --no-error-on-unmatched-pattern 2>/dev/null || {
  echo "⚠ Formatting issues detected — run 'pnpm format' to fix"
  exit 1
}

npx lint-staged
