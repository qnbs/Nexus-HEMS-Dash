{
  "name": "@nexus-hems/shared-types",
  "version": "1.11.0",
  "private": true,
  "type": "module",
  "description": "Domain-driven Zod schemas and TypeScript types shared between api and web",
  "exports": {
    ".": {
      "import": "./src/index.ts",
