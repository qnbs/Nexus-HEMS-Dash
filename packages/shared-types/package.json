{
  "name": "@nexus-hems/shared-types",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "description": "Domain-driven Zod schemas and TypeScript types shared between api and web",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "lint": "biome check src/ --config-path ../../biome.json"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "typescript": "~5.8.2"
  }
}
