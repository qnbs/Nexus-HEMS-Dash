{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri-schema/refs/heads/main/schema.json",
  "productName": "Nexus HEMS Dashboard",
  "identifier": "com.nexus-hems.dashboard",
  "version": "4.2.0",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npx vite build --base /",
    "frontendDist": "../dist"
  },
  "app": {
    "title": "Nexus HEMS Dashboard",
    "windows": [
      {
        "title": "Nexus HEMS Dashboard",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src 'self' https://api.open-meteo.com https://api.tibber.com https://api.awattar.de https://api.awattar.at https://generativelanguage.googleapis.com wss:; font-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
